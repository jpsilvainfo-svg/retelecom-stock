{
  "rewrites": [
    { "source": "/.env", "destination": "/api/security-probe?kind=env" },
    { "source": "/.env.local", "destination": "/api/security-probe?kind=env" },
    { "source": "/.git/:path*", "destination": "/api/security-probe?kind=git" },
    { "source": "/wp-admin/:path*", "destination": "/api/security-probe?kind=wp-admin" },
    { "source": "/wp-login.php", "destination": "/api/security-probe?kind=wp-login" },
    { "source": "/phpmyadmin/:path*", "destination": "/api/security-probe?kind=phpmyadmin" },
    { "source": "/adminer.php", "destination": "/api/security-probe?kind=adminer" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), geolocation=(self), microphone=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=31536000; includeSubDomains; preload" }
      ]
    }
  ]
}
